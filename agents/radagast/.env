# =====================================================================
# Radagast - variaveis de ambiente (versao gratuita)
# =====================================================================
# Agora usa apenas ferramentas gratuitas:
# - YouTube: RSS + yt-dlp (gratis)
# - Twitter: Nitter RSS (gratis)
# - Web: Google News RSS (gratis)
# - LLM: Ollama phi3:mini local (gratis)
# =====================================================================

# 1. Bot Telegram proprio seu (cria com @BotFather no Telegram)
RADAGAST_BOT_TOKEN=8811516995:AAFH0rZrize9J9UfvKqDGMXv1tnCcD4Vc78

# 2. Seu chat_id pessoal no Telegram (envia uma mensagem pro @userinfobot pra descobrir)
RADAGAST_CHAT_ID=348122485

# =====================================================================
# Opcionais
# =====================================================================

# Horario do cron diario (formato HH:MM, padrao 06:30)
RADAGAST_RUN_TIME=06:30

# Quantos dias para tras o Radagast varre em cada execucao
RADAGAST_SCAN_DAYS=3

# URL do Ollama (padrao: http://localhost:11434/api/generate)
# OLLAMA_URL=http://localhost:11434/api/generate

# Modelo Ollama (padrao: phi3:mini)
# OLLAMA_MODEL=phi3:mini
