{
  "buildCommand": null,
  "outputDirectory": "cerebro/perfil-empreendedor-solo",
  "framework": null,
  "rewrites": [
    { "source": "/", "destination": "/landing.html" },
    { "source": "/plataforma.html", "destination": "/plataforma.html" },
    { "source": "/dashboard.html", "destination": "/dashboard.html" },
    { "source": "/manifest.json", "destination": "/manifest.json" },
    { "source": "/sw.js", "destination": "/sw.js" }
  ],
  "headers": [
    { "source": "/(.*)", "headers": [{ "key": "Access-Control-Allow-Origin", "value": "*" }] }
  ]
}